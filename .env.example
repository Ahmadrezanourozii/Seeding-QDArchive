# QDArchive Configuration Template
# Create a copy as .env and populate with actual credentials

# Storage Configuration
DATA_DIR="./My_Downloads"
METADATA_DB_PATH="./My_Downloads/metadata.sqlite"

# Repository API Tokens
# Note: Zenodo, Dryad, and Dataverse often require tokens for high-rate harvesting or restricted access.
ZENODO_TOKEN=""
DRYAD_TOKEN=""
DATAVERSE_TOKEN=""
ICPSR_TOKEN=""
IHSN_TOKEN=""
SADA_TOKEN=""

# Pipeline Settings
REQUEST_INTERVAL=0.5
MAX_CONCURRENT_DOWNLOADS=5
DEBUG_MODE=False
